# Copy this file to .env and fill in your API keys
# NEVER commit .env to git!

# LLM API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...

# Webhookd Auth (optional)
WEBHOOKD_HOOKS_USER=admin
WEBHOOKD_HOOKS_PASS=changeme
WEBHOOKD_HOOKS_SECRET=your-webhook-signing-secret

# Qodo / PR-Agent
GITHUB_TOKEN=ghp_...your_github_pat...
