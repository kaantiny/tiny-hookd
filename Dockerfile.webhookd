# webhookd - Batteries Included
# Includes: webhookd + Node.js + Python3 + common CLI tools

FROM debian:bookworm-slim

LABEL maintainer="Lumo"
LABEL description="webhookd with Node.js and Python3 toolchains"

# Avoid interactive prompts
ENV DEBIAN_FRONTEND=noninteractive
ENV NODE_VERSION=20.x

# Install system dependencies
RUN apt-get update && apt-get install -y \
    # Core tools
    curl \
    wget \
    ca-certificates \
    git \
    jq \
    tar \
    gzip \
    unzip \
    # Build essentials (for native modules)
    build-essential \
    python3-dev \
    # Networking tools
    netcat-openbsd \
    dnsutils \
    iputils-ping \
    # Text processing
    vim-tiny \
    nano \
    # Docker CLI (for running PR-Agent containers)
    docker.io \
    # Cleanup
    && rm -rf /var/lib/apt/lists/*

# ============================
# Install Node.js (LTS)
# ============================
RUN curl -fsSL https://deb.nodesource.com/setup_${NODE_VERSION} | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Global npm packages (useful for webhooks)
RUN npm install -g \
    # TypeScript runtime
    ts-node \
    typescript \
    # HTTP clients
    axios \
    # CLI utilities
    nodemon \
    pm2 \
    # JSON processing
    json \
    # LLM / AI libraries
    openai \
    @anthropic-ai/sdk \
    # Retry / backoff
    p-retry \
    async-retry \
    exponential-backoff \
    # Cleanup npm cache
    && npm cache clean --force

# ============================
# Install Python3 + pip
# ============================
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    python3-venv \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf /usr/bin/python3 /usr/bin/python

# Common Python packages (pre-installed)
RUN pip3 install --break-system-packages --no-cache-dir \
    # HTTP clients
    requests \
    httpx \
    urllib3 \
    # Data processing
    pyyaml \
    toml \
    # CLI tools
    click \
    rich \
    # Utils
    python-dotenv \
    pydantic \
    # LLM / AI libraries
    openai \
    anthropic \
    google-generativeai \
    tiktoken \
    # Retry / backoff
    tenacity \
    backoff \
    retry

# ============================
# Install webhookd
# ============================
ARG WEBHOOKD_VERSION=latest
RUN ARCH=$(uname -m | sed 's/x86_64/amd64/;s/aarch64/arm64/') \
    && if [ "$WEBHOOKD_VERSION" = "latest" ]; then \
        DOWNLOAD_URL=$(curl -s https://api.github.com/repos/ncarlier/webhookd/releases/latest \
            | grep "browser_download_url.*linux-${ARCH}.tgz" \
            | cut -d '"' -f 4); \
    else \
        DOWNLOAD_URL="https://github.com/ncarlier/webhookd/releases/download/v${WEBHOOKD_VERSION}/webhookd-linux-${ARCH}.tgz"; \
    fi \
    && curl -L -o /tmp/webhookd.tgz "$DOWNLOAD_URL" \
    && tar -xzf /tmp/webhookd.tgz -C /usr/local/bin/ webhookd \
    && rm /tmp/webhookd.tgz \
    && chmod +x /usr/local/bin/webhookd

# ============================
# Setup directories
# ============================
RUN mkdir -p /var/opt/webhookd/scripts \
    && mkdir -p /var/opt/webhookd/hooks

# Working directory for scripts
WORKDIR /var/opt/webhookd

# Environment
ENV PATH="/usr/local/bin:${PATH}"
ENV WEBHOOKD_SCRIPTS_DIR=/var/opt/webhookd/scripts
ENV WEBHOOKD_HOOKS_DIR=/var/opt/webhookd/hooks
ENV WEBHOOKD_LOG_LEVEL=info

# Expose webhookd default port
EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8080/health || exit 1

# Default entrypoint
ENTRYPOINT ["webhookd"]

# Default command (can be overridden)
CMD ["--scripts", "/var/opt/webhookd/scripts", "--listen-addr", "0.0.0.0:8080"]
